PORT=5000
MONGODB_URI=mongodb://localhost:27017/luvstor
JWT_SECRET=change_this_to_a_long_random_secret

# ── SMTP (required for real emails in production) ─────────────────────────
# Gmail: enable 2FA → Google Account → Security → App passwords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_gmail@gmail.com
SMTP_PASS=your_16_char_app_password
SMTP_FROM_NAME=Luvstor
# SMTP_FROM_EMAIL=optional@yourdomain.com

# Set true to print OTP in the server console instead of sending email
SMTP_DEV_MODE=false

# OTP settings
OTP_EXPIRY_MINUTES=10
OTP_RESEND_COOLDOWN_SECONDS=60
OTP_MAX_SENDS_PER_HOUR=5
OTP_MAX_VERIFY_ATTEMPTS=5

# Other providers:
# Outlook:  SMTP_HOST=smtp.office365.com  SMTP_PORT=587
# SendGrid: SMTP_HOST=smtp.sendgrid.net   SMTP_USER=apikey  SMTP_PASS=<api_key>
# Mailgun:  SMTP_HOST=smtp.mailgun.org     SMTP_USER=postmaster@your-domain
